# Kflow server — environment variables
#
# Copy this file to .env (or .env.local / .env.development.local) and fill in
# the real values. This file is gitignored; never commit secrets.

PORT=3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:5173,http://localhost:5174

# Firebase Admin credentials
FB_PROJECT_ID=your_project_id
FB_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FB_DB_ID=(default)

# AI providers
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=...
GEMINI_API_KEY=...

# Almadar SDK credentials (interactive orbital generation)
ALMADAR_API_KEY=almadar_sk_...
ALMADAR_BASE_URL=http://localhost:3003

# Redis / Upstash (optional)
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Dev-only auth bypass. NEVER enable in production.
ALLOW_DEV_AUTH_BYPASS=true
