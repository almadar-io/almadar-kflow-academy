{
  "name": "@kflow-academy/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.js --packages=external --sourcemap",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "apollo-server-express": "^3.13.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^13.6.0",
    "graphology": "^0.26.0",
    "graphology-indices": "^0.17.0",
    "graphology-shortest-path": "^2.1.0",
    "graphql": "^16.12.0",
    "openai": "^4.20.1",
    "tiktoken": "^1.0.22",
    "type-graphql": "^2.0.0-rc.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^22.10.1",
    "esbuild": "^0.27.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
