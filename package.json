{
  "name": "kflow-academy",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "start": "node packages/server/dist/server.js",
    "dev": "concurrently -k -n server,client -c blue,green \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "pnpm --filter @kflow-academy/shared build && pnpm --filter @kflow-academy/server dev",
    "dev:client": "pnpm --filter @kflow-academy/client dev",
    "build": "pnpm run build:server",
    "build:all": "pnpm -r --if-present build",
    "build:shared": "pnpm --filter @kflow-academy/shared build",
    "build:client": "pnpm run build:shared && pnpm --filter @kflow-academy/client build",
    "build:server": "pnpm run build:shared && pnpm --filter @kflow-academy/server build",
    "test": "pnpm -r --if-present test",
    "test:e2e": "node e2e/flows.mjs",
    "test:e2e:sdk-lesson": "node e2e/sdk-lesson.mjs",
    "lint": "pnpm -r --if-present lint",
    "clean": "pnpm -r --if-present clean && rm -rf node_modules",
    "deploy:prod": "pnpm run build:client && firebase deploy --only hosting:prod",
    "deploy:dev": "pnpm run build:client && firebase deploy --only hosting:dev",
    "deploy:server": "pnpm run build:server && firebase deploy --only apphosting",
    "deploy:all": "pnpm run deploy:prod && pnpm run deploy:server",
    "firebase:use": "firebase use kflow-b3a39"
  },
  "dependencies": {
    "@almadar-io/knowledge": "^0.7.3",
    "three": "^0.160.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "concurrently": "^9.1.0",
    "esbuild": "^0.27.2",
    "playwright": "^1.61.0",
    "prettier": "^3.4.2",
    "turbo": "^2.8.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "engines": {
    "node": "22"
  }
}
