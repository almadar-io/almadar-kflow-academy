{
  "hosting": [
    {
      "target": "client",
      "public": "packages/client/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ]
    }
  ],
  "apphosting": {
    "backendId": "kflow-academy-server",
    "rootDir": ".",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "packages/client",
      "**/dist",
      "**/__tests__",
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.stories.ts",
      "**/*.stories.tsx",
      "docs",
      "**/docs",
      "**/*.md",
      "*.log",
      "*.tsbuildinfo",
      ".env",
      ".env.*"
    ]
  },
  "firestore": {
    "database": "kflow",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
